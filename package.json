{
	"name": "doclocalizer",
	"version": "0.1.0",
	"private": true,
	"author": "zimablue-io",
	"type": "module",
	"description": "Document localization with AI",
	"license": "SEE LICENSE IN LICENSE.md",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"dev:desktop": "pnpm --filter @doclocalizer/desktop tauri dev",
		"dev:landing": "pnpm --filter @doclocalizer/landing dev",
		"build:core": "pnpm --filter @doclocalizer/core build",
		"build:desktop": "pnpm --filter @doclocalizer/desktop build",
		"build:landing": "pnpm --filter @doclocalizer/landing build",
		"build": "pnpm run build:core && pnpm run build:desktop",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"test": "vitest run",
		"knip": "knip",
		"knip:fix": "knip --fix"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^22.15.3",
		"knip": "^6.7.0",
		"release-please": "^17.0.0",
		"typescript": "^5.8.3",
		"vitest": "^4.1.4"
	}
}
