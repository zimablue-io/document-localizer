{
	"name": "Document Localizer",
	"short_name": "DocLocalizer",
	"description": "AI-Powered PDF & Markdown Localization. Local, Private, Free.",
	"start_url": "/",
	"scope": "/",
	"display": "standalone",
	"background_color": "#0a0a0f",
	"theme_color": "#6366f1",
	"icons": [
		{
			"src": "/apple-touch-icon.png",
			"sizes": "180x180",
			"type": "image/png",
			"purpose": "any"
		},
		{
			"src": "/favicon.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		}
	]
}
